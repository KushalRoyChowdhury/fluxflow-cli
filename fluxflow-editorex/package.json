{
    "name": "fluxflow-cli-companion",
    "displayName": "FluxFlow-CLI Companion",
    "publisher": "fluxflow-cli",
    "icon": "fluxflow-cli-companion.png",
    "description": "Enable FluxFlow CLI with direct access to your IDE workspace.",
    "version": "1.4.1",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "AI"
    ],
    "activationEvents": [
        "*"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "fluxflow-editorx.run",
                "title": "FluxFlow: Run"
            },
            {
                "command": "fluxflow-editorex.startCompanion",
                "title": "FluxFlow: Start Companion"
            },
            {
                "command": "fluxflow-editorex.chat",
                "title": "Chat"
            },
            {
                "command": "fluxflow-editorex.fixErrors",
                "title": "Fix Errors",
                "icon": "$(sparkle)"
            },
            {
                "command": "fluxflow-editorex.fixWarnings",
                "title": "Fix Warnings/Lint",
                "icon": "$(info)"
            },
            {
                "command": "fluxflow-editorex.acceptDiff",
                "title": "Accept (FluxFlow)",
                "icon": "$(check)"
            },
            {
                "command": "fluxflow-editorex.denyDiff",
                "title": "Deny (FluxFlow)",
                "icon": "$(close)"
            }
        ],
        "submenus": [
            {
                "id": "fluxflow.submenu",
                "label": "FluxFlow",
                "icon": "$(zap)"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "fluxflow-editorex.startCompanion",
                    "when": "false"
                },
                {
                    "command": "fluxflow-editorex.chat",
                    "when": "true"
                }
            ],
            "editor/context": [
                {
                    "submenu": "fluxflow.submenu",
                    "group": "navigation",
                    "when": "editorTextFocus"
                }
            ],
            "editor/title/context": [
                {
                    "submenu": "fluxflow.submenu",
                    "group": "navigation"
                }
            ],
            "explorer/context": [
                {
                    "submenu": "fluxflow.submenu",
                    "group": "navigation"
                }
            ],
            "fluxflow.submenu": [
                {
                    "command": "fluxflow-editorex.chat",
                    "group": "1_main"
                },
                {
                    "command": "fluxflow-editorex.fixErrors",
                    "group": "2_fix",
                    "when": "fluxflow.hasErrors"
                },
                {
                    "command": "fluxflow-editorex.fixWarnings",
                    "group": "2_fix",
                    "when": "fluxflow.activeFileHasWarnings"
                }
            ],
            "editor/title": [
                {
                    "command": "fluxflow-editorex.fixErrors",
                    "group": "navigation",
                    "when": "fluxflow.hasErrors"
                },
                {
                    "command": "fluxflow-editorex.acceptDiff",
                    "group": "navigation",
                    "when": "fluxflow.isDiffVisible"
                },
                {
                    "command": "fluxflow-editorex.denyDiff",
                    "group": "navigation",
                    "when": "fluxflow.isDiffVisible"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "pnpm run package",
        "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.90.0",
        "@types/ws": "^8.18.1",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.27.3",
        "eslint": "^9.39.3",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "dependencies": {
        "ws": "^8.21.0"
    }
}
